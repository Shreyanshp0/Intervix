const cloudinaryService = require('../services/cloudinary.service');

exports.getStorageHealth = async (req, res) => {
  try {
    const pingResult = await cloudinaryService.checkHealth();
    res.status(200).json({
      status: 'healthy',
      service: 'Cloudinary',
      details: pingResult
    });
  } catch (error) {
    res.status(503).json({
      status: 'unhealthy',
      service: 'Cloudinary',
      error: error.message
    });
  }
};

