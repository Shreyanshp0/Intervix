# Docker Compose defaults.
# Copy to .env at the repository root for local Docker or server deployment.

NODE_ENV=production
APP_DOMAIN=localhost

BACKEND_PORT=5000
FRONTEND_PORT=3000

FRONTEND_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5000
VITE_API_URL=/api

BACKEND_IMAGE=intervix-backend:local
FRONTEND_IMAGE=intervix-frontend:local
