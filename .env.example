# Docker Compose defaults.
# Copy to .env at the repository root for local Docker or server deployment.

NODE_ENV=production
APP_DOMAIN=intervix.duckdns.org

BACKEND_PORT=5000
FRONTEND_PORT=3000

FRONTEND_URL=https://intervix.duckdns.org
PUBLIC_APP_URL=https://intervix.duckdns.org
TRUSTED_ORIGINS=https://intervix.duckdns.org
VITE_API_URL=/api
VITE_SOCKET_URL=

BACKEND_IMAGE=intervix-backend:local
FRONTEND_IMAGE=intervix-frontend:local
